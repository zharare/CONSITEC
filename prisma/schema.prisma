generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SALES
}

enum ServiceStatus {
  SCHEDULED
  EXECUTED
  INVOICED
  PAID
}

enum CustomerType {
  NATURAL_PERSON
  COMPANY
}

model User {
  id       String @id
  username String @unique
  password String
  role     String
}

model Instructor {
  id       String    @id @default(cuid())
  name     String    @unique
  services Service[]
}

model Course {
  id               String            @id @default(cuid())
  name             String            @unique
  services         Service[]
  certificateSales CertificateSale[]
}

model Salesperson {
  id               String            @id @default(cuid())
  name             String            @unique
  services         Service[]
  certificateSales CertificateSale[]
}

model Location {
  id         String    @id @default(cuid())
  department String
  district   String
  services   Service[]

  @@unique([department, district])
}

model Service {
  id               String        @id @default(cuid())
  company          String
  amount           Decimal       @db.Decimal(10, 2)
  serviceDate      DateTime
  certificatesOnly Boolean       @default(false)
  status           ServiceStatus @default(SCHEDULED)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  courseId       String
  instructorId   String?     // 👈 OPCIONAL
  locationId     String?     // 👈 OPCIONAL
  salespersonId  String

  course        Course      @relation(fields: [courseId], references: [id])
  instructor    Instructor? @relation(fields: [instructorId], references: [id], onDelete: SetNull)
  location      Location?   @relation(fields: [locationId], references: [id])
  salesperson   Salesperson @relation(fields: [salespersonId], references: [id])

  @@index([serviceDate])
}

model CertificateSale {
  id            String        @id @default(cuid())
  customerName  String
  customerType  CustomerType
  amount        Decimal       @db.Decimal(10, 2)
  saleDate      DateTime
  status        ServiceStatus @default(SCHEDULED)
  createdAt     DateTime      @default(now())

  courseId      String
  salespersonId String

  course        Course       @relation(fields: [courseId], references: [id])
  salesperson   Salesperson  @relation(fields: [salespersonId], references: [id])

  @@index([saleDate])
}
